# Line ending normalization
# Use LF (Unix-style) for all text files - GitHub recommended
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.pdf binary
*.zip binary

# GitHub Release Exclusions
.github/          export-ignore
tests/            export-ignore
build/            export-ignore
scripts/          export-ignore
.gitignore        export-ignore
.gitattributes    export-ignore
.distignore       export-ignore
composer.json     export-ignore
composer.lock     export-ignore
phpstan.neon      export-ignore
phpstan.neon.dist export-ignore
phpstan-baseline.neon export-ignore
package.json      export-ignore
package-lock.json export-ignore
DEVELOPMENT.md    export-ignore
USER_GUIDE.md     export-ignore
SECURITY_AUDIT_REPORT.md export-ignore
